page {
  min-height: 100vh;
  background: #f5f7f5;
  color: #101412;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", sans-serif;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  width: 100%;
  min-width: 0;
  margin: 0;
  padding: 0;
  border-radius: 16rpx;
  font-size: 29rpx;
  line-height: 1;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 52rpx;
}

.section {
  margin-bottom: 22rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(14, 22, 18, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 44rpx rgba(13, 21, 18, 0.06);
}

.surface {
  border: 1rpx solid rgba(14, 22, 18, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.92);
}

.eyebrow {
  display: block;
  color: #65706a;
  font-size: 21rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.title {
  margin-top: 10rpx;
  color: #101412;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.12;
}

.section-title {
  color: #101412;
  font-size: 32rpx;
  font-weight: 860;
  line-height: 1.18;
}

.muted {
  color: #6b746f;
  font-size: 25rpx;
  line-height: 1.55;
}

.primary-btn,
.secondary-btn,
.danger-btn {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  font-weight: 850;
}

.primary-btn {
  background: #101412;
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(16, 20, 18, 0.18);
}

.secondary-btn {
  border: 1rpx solid rgba(16, 20, 18, 0.1);
  background: #ffffff;
  color: #101412;
}

.danger-btn {
  border: 1rpx solid rgba(206, 82, 72, 0.2);
  background: #fff1ef;
  color: #c7443a;
}

.field {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  color: #65706a;
  font-size: 25rpx;
  font-weight: 760;
}

.input,
.textarea,
.picker-value {
  width: 100%;
  min-height: 86rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid rgba(16, 20, 18, 0.1);
  border-radius: 16rpx;
  background: #ffffff;
  color: #101412;
  font-size: 30rpx;
}

.input,
.picker-value {
  display: flex;
  align-items: center;
}

.textarea {
  min-height: 150rpx;
  line-height: 1.55;
}

.two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  min-height: 68rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  border: 1rpx solid rgba(16, 20, 18, 0.1);
  border-radius: 999rpx;
  background: #ffffff;
  color: #333b36;
  font-size: 27rpx;
  font-weight: 760;
}

.chip.active {
  border-color: rgba(28, 123, 94, 0.32);
  background: #e9f7f0;
  color: #14634a;
}

.empty {
  padding: 30rpx 0 8rpx;
  color: #7a837e;
  font-size: 28rpx;
  line-height: 1.7;
}

.health-note {
  padding: 24rpx 26rpx;
  border: 1rpx solid rgba(206, 135, 50, 0.18);
  border-radius: 16rpx;
  background: #fff8e9;
  color: #5d5036;
  font-size: 27rpx;
  line-height: 1.65;
}
