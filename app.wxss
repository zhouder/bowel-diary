page {
  min-height: 100vh;
  background: #f2f2f7;
  color: #1d1d1f;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", sans-serif;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  display: block;
  width: 100%;
  min-width: 0;
  height: 84rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: transparent;
  color: #1d1d1f;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 84rpx;
  text-align: center;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 56rpx;
}

.section {
  margin-bottom: 22rpx;
  padding: 0;
  overflow: hidden;
  border-radius: 22rpx;
  background: #ffffff;
}

.surface {
  overflow: hidden;
  border-radius: 22rpx;
  background: #ffffff;
}

.page-heading {
  margin: 18rpx 0 22rpx;
}

.page-title {
  color: #1d1d1f;
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1.12;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #8e8e93;
  font-size: 28rpx;
  line-height: 1.4;
}

.eyebrow {
  display: block;
  color: #8e8e93;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0;
}

.title {
  margin-top: 6rpx;
  color: #1d1d1f;
  font-size: 38rpx;
  font-weight: 650;
  line-height: 1.2;
}

.section-title {
  color: #1d1d1f;
  font-size: 32rpx;
  font-weight: 650;
  line-height: 1.25;
}

.muted {
  color: #8e8e93;
  font-size: 26rpx;
  line-height: 1.48;
}

.primary-btn,
.secondary-btn,
.danger-btn {
  display: block;
  width: 100%;
  height: 84rpx;
  min-height: 84rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 84rpx;
  text-align: center;
}

.primary-btn {
  background: #007aff;
  color: #ffffff;
}

.primary-btn.disabled {
  opacity: 0.48;
}

.secondary-btn {
  background: #f2f2f7;
  color: #007aff;
}

.danger-btn {
  background: #fff1f0;
  color: #ff3b30;
}

.field {
  margin-bottom: 22rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #6e6e73;
  font-size: 25rpx;
  font-weight: 600;
}

.input,
.textarea,
.picker-value {
  width: 100%;
  min-height: 88rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid rgba(60, 60, 67, 0.14);
  border-radius: 16rpx;
  background: #ffffff;
  color: #1d1d1f;
  font-size: 30rpx;
}

.input,
.picker-value {
  display: flex;
  align-items: center;
  line-height: 1.3;
}

.textarea {
  min-height: 148rpx;
  line-height: 1.55;
}

.two-col {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  min-height: 66rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #f2f2f7;
  color: #1d1d1f;
  font-size: 27rpx;
  font-weight: 500;
}

.chip.active {
  background: rgba(0, 122, 255, 0.12);
  color: #007aff;
}

.empty {
  padding: 26rpx 0 8rpx;
  color: #8e8e93;
  font-size: 28rpx;
  line-height: 1.6;
}

.health-note {
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #fff7e8;
  color: #7a5a18;
  font-size: 26rpx;
  line-height: 1.58;
}
