page {
  min-height: 100vh;
  background: #f8f5ef;
  color: #22211f;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  width: 100%;
  min-width: 0;
  margin: 0;
  padding: 0;
  border-radius: 8px;
  font-size: 30rpx;
  line-height: 1;
}

button::after {
  border: none;
}

.page {
  padding: 28rpx;
}

.section {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border: 1rpx solid #ded8cd;
  border-radius: 16rpx;
  background: #fffdf8;
  box-shadow: 0 18rpx 44rpx rgba(61, 52, 38, 0.08);
}

.eyebrow {
  color: #6e6a61;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.title {
  margin-top: 8rpx;
  color: #111111;
  font-size: 42rpx;
  font-weight: 850;
  line-height: 1.16;
}

.section-title {
  color: #111111;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.muted {
  color: #6e6a61;
  font-size: 26rpx;
  line-height: 1.6;
}

.primary-btn,
.secondary-btn,
.danger-btn {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  font-weight: 800;
}

.primary-btn {
  background: #22211f;
  color: #ffffff;
}

.secondary-btn {
  border: 1rpx solid rgba(79, 154, 120, 0.28);
  background: #e4f2eb;
  color: #22211f;
}

.danger-btn {
  border: 1rpx solid rgba(185, 74, 74, 0.24);
  background: #fae6df;
  color: #b94a4a;
}

.field {
  margin-bottom: 22rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #6e6a61;
  font-size: 26rpx;
  font-weight: 750;
}

.input,
.textarea,
.picker-value {
  width: 100%;
  min-height: 84rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid #ded8cd;
  border-radius: 14rpx;
  background: #ffffff;
  color: #22211f;
  font-size: 30rpx;
}

.textarea {
  min-height: 140rpx;
  line-height: 1.55;
}

.two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  min-height: 68rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  border: 1rpx solid #ded8cd;
  border-radius: 14rpx;
  background: #ffffff;
  color: #22211f;
  font-size: 28rpx;
  font-weight: 700;
}

.chip.active {
  border-color: rgba(79, 154, 120, 0.46);
  background: #e4f2eb;
  color: #236548;
}

.empty {
  padding: 28rpx 0;
  color: #6e6a61;
  font-size: 28rpx;
  line-height: 1.7;
}

.health-note {
  padding: 24rpx;
  border-radius: 14rpx;
  background: #f6ecd6;
  color: #3f3728;
  font-size: 28rpx;
  line-height: 1.7;
}
