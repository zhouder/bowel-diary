page {
  min-height: 100vh;
  background: #f5f5f7;
  color: #1d1d1f;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", sans-serif;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  display: block;
  width: 100%;
  min-width: 0;
  height: 88rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: transparent;
  color: #1d1d1f;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 56rpx;
}

.section {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 46rpx rgba(0, 0, 0, 0.05);
}

.surface {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
}

.eyebrow {
  display: block;
  color: #86868b;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.title {
  margin-top: 8rpx;
  color: #1d1d1f;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.1;
}

.section-title {
  color: #1d1d1f;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.muted {
  color: #86868b;
  font-size: 26rpx;
  line-height: 1.55;
}

.primary-btn,
.secondary-btn,
.danger-btn {
  display: block;
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 22rpx;
  font-size: 30rpx;
  font-weight: 750;
  line-height: 88rpx;
  text-align: center;
}

.primary-btn {
  background: #007aff;
  color: #ffffff;
}

.primary-btn.disabled {
  opacity: 0.48;
}

.secondary-btn {
  background: #f2f2f7;
  color: #007aff;
}

.danger-btn {
  background: #fff2f2;
  color: #ff3b30;
}

.field {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  color: #6e6e73;
  font-size: 26rpx;
  font-weight: 650;
}

.input,
.textarea,
.picker-value {
  width: 100%;
  min-height: 92rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  border-radius: 20rpx;
  background: #ffffff;
  color: #1d1d1f;
  font-size: 30rpx;
}

.input,
.picker-value {
  display: flex;
  align-items: center;
  line-height: 1.3;
}

.textarea {
  min-height: 156rpx;
  line-height: 1.55;
}

.two-col {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 18rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  min-height: 70rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f2f2f7;
  color: #1d1d1f;
  font-size: 27rpx;
  font-weight: 650;
}

.chip.active {
  background: rgba(0, 122, 255, 0.12);
  color: #007aff;
}

.empty {
  padding: 30rpx 0 8rpx;
  color: #86868b;
  font-size: 28rpx;
  line-height: 1.7;
}

.health-note {
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: #fff7e8;
  color: #6e4c12;
  font-size: 27rpx;
  line-height: 1.65;
}
