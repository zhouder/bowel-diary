.ai-hero {
  background: linear-gradient(135deg, #fffdf8 0%, #e5edf6 100%);
}

.context-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.context-pill {
  min-height: 62rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  border-radius: 14rpx;
  background: #e5edf6;
  color: #426f9f;
  font-size: 26rpx;
  font-weight: 800;
}

.setting-btn {
  margin-top: 16rpx;
}

.error-box {
  margin-top: 20rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(185, 74, 74, 0.28);
  border-radius: 14rpx;
  background: #fae7e7;
  color: #b94a4a;
  font-size: 28rpx;
  line-height: 1.7;
}

.answer-box {
  margin-top: 22rpx;
  padding: 24rpx;
  border: 1rpx solid #ded8cd;
  border-radius: 14rpx;
  background: #ffffff;
  color: #22211f;
  font-size: 29rpx;
  line-height: 1.8;
  white-space: pre-wrap;
}
