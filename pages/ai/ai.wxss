.ai-page {
  padding-top: 24rpx;
}

.ai-hero {
  margin-bottom: 24rpx;
  padding: 22rpx 0 0;
}

.ai-kicker {
  color: #86868b;
  font-size: 24rpx;
  font-weight: 650;
}

.ai-title {
  margin-top: 8rpx;
  color: #1d1d1f;
  font-size: 60rpx;
  font-weight: 850;
  line-height: 1.05;
}

.ai-subtitle {
  margin-top: 10rpx;
  color: #6e6e73;
  font-size: 28rpx;
  line-height: 1.42;
}

.context-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.context-pill {
  min-height: 62rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(0, 122, 255, 0.12);
  color: #007aff;
  font-size: 25rpx;
  font-weight: 700;
}

.setting-btn {
  margin-top: 16rpx;
}

.error-box {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #fff2f2;
  color: #ff3b30;
  font-size: 27rpx;
  line-height: 1.7;
}

.answer-box {
  margin-top: 22rpx;
  padding: 26rpx;
  border-radius: 22rpx;
  background: #f2f2f7;
  color: #1d1d1f;
  font-size: 29rpx;
  line-height: 1.82;
  white-space: pre-wrap;
}
