.ai-page {
  padding-top: 24rpx;
}

.ai-page .section {
  padding: 24rpx 26rpx 28rpx;
}

.context-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 22rpx;
}

.context-pill {
  min-height: 56rpx;
  display: flex;
  align-items: center;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f2f2f7;
  color: #6e6e73;
  font-size: 25rpx;
  font-weight: 500;
}

.setting-btn {
  margin-top: 14rpx;
}

.error-box {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #fff1f0;
  color: #ff3b30;
  font-size: 27rpx;
  line-height: 1.6;
}

.answer-box {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #f2f2f7;
  color: #1d1d1f;
  font-size: 28rpx;
  line-height: 1.75;
  white-space: pre-wrap;
}
