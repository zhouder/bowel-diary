<view class="page ai-page">
  <view class="page-heading">
    <view class="page-title">饮食建议</view>
    <view class="page-subtitle">Xiaomi MiMo · Token Plan</view>
  </view>

  <view class="section">
    <view class="context-row">
      <view class="context-pill">{{contextCount.bowels}} 条排便</view>
      <view class="context-pill">{{contextCount.meals}} 条饮食</view>
      <view class="context-pill">近 21 天</view>
    </view>

    <view class="primary-btn {{loading ? 'disabled' : ''}}" bindtap="generate">{{loading ? '生成中' : '生成建议'}}</view>
    <view wx:if="{{!hasSettings}}" class="secondary-btn setting-btn" bindtap="goSettings">先去设置 API</view>

    <view wx:if="{{error}}" class="error-box">{{error}}</view>

    <view wx:if="{{answer}}" class="answer-box">
      <text user-select>{{answer}}</text>
    </view>

    <view wx:if="{{!answer && !error}}" class="empty">
      等待记录数据。
    </view>
  </view>

  <view class="health-note">
    AI 只做生活方式建议，不诊断疾病，不开药，不替代医生。
  </view>
</view>
