.dashboard-page {
  padding-top: 24rpx;
}

.quick-actions {
  margin-bottom: 22rpx;
  overflow: hidden;
  border-radius: 22rpx;
  background: #ffffff;
}

.action-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 26rpx;
  border-bottom: 1rpx solid rgba(60, 60, 67, 0.12);
}

.action-row:last-child {
  border-bottom: none;
}

.action-title {
  color: #1d1d1f;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.25;
}

.stats-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.stat-card {
  min-height: 164rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #ffffff;
}

.stat-label {
  color: #8e8e93;
  font-size: 25rpx;
  line-height: 1.25;
}

.stat-value {
  color: #1d1d1f;
  font-size: 36rpx;
  font-weight: 650;
  line-height: 1.1;
}

.stat-foot {
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.35;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 26rpx 18rpx;
}

.mini-btn {
  width: 104rpx;
  height: 56rpx;
  min-height: 56rpx;
  flex: 0 0 104rpx;
  padding: 0;
  border-radius: 16rpx;
  background: #f2f2f7;
  color: #007aff;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 56rpx;
  text-align: center;
}

.rhythm-row {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 7rpx;
  padding: 0 18rpx 22rpx;
}

.rhythm-day {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 9rpx;
  align-items: center;
  padding: 12rpx 4rpx;
  border-radius: 16rpx;
  background: #f2f2f7;
}

.day-label {
  color: #1d1d1f;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.1;
}

.bar-track {
  width: 54rpx;
  height: 102rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 4rpx;
  padding: 8rpx;
  border-radius: 14rpx;
  background: #ffffff;
}

.bar {
  width: 10rpx;
  min-height: 8rpx;
  border-radius: 999rpx;
}

.bar.bowel {
  background: #ff3b30;
}

.bar.water {
  background: #007aff;
}

.bar.fiber {
  background: #34c759;
}

.day-count {
  color: #8e8e93;
  font-size: 21rpx;
  font-weight: 500;
  line-height: 1.2;
}

.log-item {
  padding: 22rpx 26rpx;
  border-top: 1rpx solid rgba(60, 60, 67, 0.12);
}

.log-main {
  margin-bottom: 8rpx;
}

.log-title {
  color: #1d1d1f;
  font-size: 30rpx;
  font-weight: 600;
}

.log-note {
  color: #3a3a3c;
  font-size: 27rpx;
  line-height: 1.56;
}

.tool-list {
  overflow: hidden;
}

.tool-row {
  min-height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 26rpx;
  border-top: 1rpx solid rgba(60, 60, 67, 0.12);
}

.tool-title {
  color: #1d1d1f;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.25;
}

.chevron {
  flex: 0 0 28rpx;
  color: #c7c7cc;
  font-size: 40rpx;
  line-height: 1;
}
