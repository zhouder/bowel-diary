.dashboard-page {
  padding-top: 24rpx;
}

.hero {
  margin-bottom: 24rpx;
  padding: 34rpx 30rpx 30rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7f7fa 100%);
  box-shadow: 0 18rpx 46rpx rgba(0, 0, 0, 0.05);
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-kicker {
  color: #86868b;
  font-size: 24rpx;
  font-weight: 650;
  letter-spacing: 0;
}

.hero-title {
  margin-top: 8rpx;
  color: #1d1d1f;
  font-size: 64rpx;
  font-weight: 850;
  line-height: 1.02;
}

.hero-subtitle {
  margin-top: 10rpx;
  color: #6e6e73;
  font-size: 28rpx;
  line-height: 1.42;
}

.hero-orbit {
  width: 118rpx;
  height: 118rpx;
  flex: 0 0 118rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #f2f2f7;
}

.orbit-value {
  color: #007aff;
  font-size: 42rpx;
  font-weight: 850;
  line-height: 1;
}

.orbit-label {
  margin-top: 8rpx;
  color: #86868b;
  font-size: 20rpx;
  font-weight: 750;
}

.hero-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16rpx;
  margin-top: 32rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  min-height: 180rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.04);
}

.stat-label {
  color: #86868b;
  font-size: 25rpx;
  line-height: 1.25;
}

.stat-value {
  color: #1d1d1f;
  font-size: 40rpx;
  font-weight: 850;
  line-height: 1.08;
}

.stat-foot {
  color: #86868b;
  font-size: 24rpx;
  line-height: 1.35;
}

.accent-green .stat-value {
  color: #34c759;
}

.accent-blue .stat-value {
  color: #007aff;
}

.accent-coral .stat-value {
  color: #ff9500;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.mini-btn {
  width: 128rpx;
  height: 64rpx;
  min-height: 64rpx;
  flex: 0 0 128rpx;
  padding: 0;
  border-radius: 18rpx;
  background: #f2f2f7;
  color: #007aff;
  font-size: 26rpx;
  font-weight: 750;
  line-height: 64rpx;
  text-align: center;
}

.rhythm-row {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 8rpx;
}

.rhythm-day {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  align-items: center;
  padding: 14rpx 6rpx;
  border-radius: 20rpx;
  background: #f5f5f7;
}

.day-label {
  color: #1d1d1f;
  font-size: 21rpx;
  font-weight: 750;
  line-height: 1.1;
}

.bar-track {
  width: 58rpx;
  height: 112rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 5rpx;
  padding: 8rpx;
  border-radius: 16rpx;
  background: #ffffff;
}

.bar {
  width: 11rpx;
  min-height: 8rpx;
  border-radius: 999rpx;
}

.bar.bowel {
  background: #ff3b30;
}

.bar.water {
  background: #007aff;
}

.bar.fiber {
  background: #34c759;
}

.day-count {
  color: #86868b;
  font-size: 21rpx;
  font-weight: 650;
  line-height: 1.2;
}

.log-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(60, 60, 67, 0.12);
}

.log-item:last-child {
  border-bottom: none;
}

.log-main {
  margin-bottom: 10rpx;
}

.log-title {
  color: #1d1d1f;
  font-size: 30rpx;
  font-weight: 750;
}

.log-note {
  color: #3a3a3c;
  font-size: 27rpx;
  line-height: 1.62;
}

.tool-list {
  overflow: hidden;
  border-radius: 24rpx;
  background: #f2f2f7;
}

.tool-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 22rpx;
  border-bottom: 1rpx solid rgba(60, 60, 67, 0.12);
}

.tool-row:last-child {
  border-bottom: none;
}

.tool-title {
  color: #1d1d1f;
  font-size: 30rpx;
  font-weight: 750;
  line-height: 1.25;
}

.chevron {
  flex: 0 0 28rpx;
  color: #c7c7cc;
  font-size: 44rpx;
  line-height: 1;
}
