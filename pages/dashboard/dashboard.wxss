.dashboard-page {
  padding-top: 24rpx;
}

.hero {
  margin-bottom: 22rpx;
  padding: 34rpx 32rpx 30rpx;
  border-radius: 20rpx;
  background: #101412;
  color: #ffffff;
  box-shadow: 0 28rpx 70rpx rgba(16, 20, 18, 0.22);
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 28rpx;
}

.hero-kicker {
  color: rgba(255, 255, 255, 0.58);
  font-size: 21rpx;
  font-weight: 850;
  letter-spacing: 0;
}

.hero-title {
  margin-top: 12rpx;
  color: #ffffff;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1.02;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.64);
  font-size: 27rpx;
  line-height: 1.45;
}

.hero-orbit {
  width: 118rpx;
  height: 118rpx;
  flex: 0 0 118rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
}

.orbit-value {
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.orbit-label {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.58);
  font-size: 20rpx;
  font-weight: 850;
}

.hero-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 34rpx;
}

.hero-actions button {
  flex: 1 1 0;
  width: 0;
}

.hero .primary-btn {
  background: #ffffff;
  color: #101412;
  box-shadow: none;
}

.ghost-btn {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 850;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.stat-card {
  min-height: 178rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(16, 20, 18, 0.08);
  border-radius: 16rpx;
  background: #ffffff;
}

.stat-card::before {
  content: "";
  position: absolute;
  left: 24rpx;
  top: 22rpx;
  width: 42rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #27a576;
}

.accent-blue::before {
  background: #386cf4;
}

.accent-coral::before {
  background: #d86352;
}

.accent-ink::before {
  background: #101412;
}

.stat-label {
  margin-top: 14rpx;
  color: #68736d;
  font-size: 25rpx;
  line-height: 1.2;
}

.stat-value {
  color: #101412;
  font-size: 39rpx;
  font-weight: 900;
  line-height: 1.1;
}

.stat-foot {
  color: #7a837e;
  font-size: 24rpx;
  line-height: 1.35;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.mini-btn {
  width: 128rpx;
  min-height: 62rpx;
  flex: 0 0 128rpx;
  border: 1rpx solid rgba(16, 20, 18, 0.1);
  background: #ffffff;
  color: #101412;
  font-size: 25rpx;
  font-weight: 820;
}

.rhythm-row {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 8rpx;
}

.rhythm-day {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  align-items: center;
  padding: 14rpx 8rpx;
  border: 1rpx solid rgba(16, 20, 18, 0.08);
  border-radius: 14rpx;
  background: #fbfcfb;
}

.day-label {
  color: #101412;
  font-size: 21rpx;
  font-weight: 850;
  line-height: 1.1;
}

.bar-track {
  width: 62rpx;
  height: 116rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 5rpx;
  padding: 9rpx;
  border-radius: 14rpx;
  background: #eef2f0;
}

.bar {
  width: 12rpx;
  min-height: 8rpx;
  border-radius: 999rpx 999rpx 4rpx 4rpx;
}

.bar.bowel {
  background: #d86352;
}

.bar.water {
  background: #386cf4;
}

.bar.fiber {
  background: #27a576;
}

.day-count {
  color: #7a837e;
  font-size: 21rpx;
  font-weight: 760;
  line-height: 1.2;
}

.log-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(16, 20, 18, 0.07);
}

.log-item:last-child {
  border-bottom: none;
}

.log-main {
  margin-bottom: 10rpx;
}

.log-title {
  color: #101412;
  font-size: 30rpx;
  font-weight: 860;
}

.log-note {
  color: #3f4842;
  font-size: 27rpx;
  line-height: 1.62;
}

.tool-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.tool-grid button:first-child {
  grid-column: span 2;
}
