<view class="page dashboard-page">
  <view class="page-heading">
    <view class="page-title">今天</view>
    <view class="page-subtitle">LLW 的饮食与排便记录</view>
  </view>

  <view class="quick-actions">
    <view class="action-row" bindtap="goAddBowel">
      <view>
        <view class="action-title">记录排便</view>
        <view class="muted">{{stats.lastBowelText}}</view>
      </view>
      <text class="chevron">›</text>
    </view>
    <view class="action-row" bindtap="goAddMeal">
      <view>
        <view class="action-title">记录饮食</view>
        <view class="muted">水分、纤维和餐食</view>
      </view>
      <text class="chevron">›</text>
    </view>
  </view>

  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-label">上次排便</text>
      <view class="stat-value">{{stats.daysSinceLastText}}</view>
      <text class="stat-foot">{{stats.lastBowelText}}</text>
    </view>
    <view class="stat-card">
      <text class="stat-label">7 天次数</text>
      <view class="stat-value">{{stats.last7BowelCount}} 次</view>
      <text class="stat-foot">每周节律</text>
    </view>
    <view class="stat-card">
      <text class="stat-label">14 天形态</text>
      <view class="stat-value">{{stats.avgBristolText}}</view>
      <text class="stat-foot">偏硬 {{stats.hardRateText}}</text>
    </view>
    <view class="stat-card">
      <text class="stat-label">日均饮水</text>
      <view class="stat-value">{{stats.avgWaterText}}</view>
      <text class="stat-foot">纤维 {{stats.avgFiberText}}</text>
    </view>
  </view>

  <view class="section rhythm-section">
    <view class="section-head">
      <view>
        <view class="section-title">本周</view>
        <view class="muted">排便、水分和纤维节律</view>
      </view>
      <view class="mini-btn" bindtap="goRecords">查看</view>
    </view>

    <view class="rhythm-row">
      <view class="rhythm-day" wx:for="{{stats.dailyRows}}" wx:key="key">
        <view class="day-label">{{item.label}}</view>
        <view class="bar-track">
          <view class="bar bowel" style="height: {{item.bowelHeight}}%;"></view>
          <view class="bar water" style="height: {{item.waterHeight}}%;"></view>
          <view class="bar fiber" style="height: {{item.fiberHeight}}%;"></view>
        </view>
        <view class="day-count">{{item.bowelCount}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">最近排便</view>
      <view class="mini-btn" bindtap="goAi">AI</view>
    </view>

    <view wx:if="{{stats.recentBowels.length}}">
      <view class="log-item" wx:for="{{stats.recentBowels}}" wx:key="id">
        <view class="log-main">
          <view class="log-title">{{item.bristolText}}</view>
          <view class="muted">{{item.timeText}} · {{item.minutes}} 分钟 · 顺畅度 {{item.ease}}</view>
        </view>
        <view class="log-note">{{item.detailText}}</view>
      </view>
    </view>
    <view wx:else class="empty">暂无排便记录</view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">更多</view>
    </view>
    <view class="tool-list">
      <view class="tool-row" bindtap="goRecords">
        <view>
          <view class="tool-title">记录列表</view>
          <view class="muted">查看排便和饮食时间线</view>
        </view>
        <text class="chevron">›</text>
      </view>
      <view class="tool-row" bindtap="goAi">
        <view>
          <view class="tool-title">AI 建议</view>
          <view class="muted">基于最近 21 天记录生成</view>
        </view>
        <text class="chevron">›</text>
      </view>
      <view class="tool-row" bindtap="goSettings">
        <view>
          <view class="tool-title">设置</view>
          <view class="muted">小米 Token Plan 和备份</view>
        </view>
        <text class="chevron">›</text>
      </view>
    </view>
  </view>

  <view class="health-note">
    如出现便血、持续腹痛、呕吐、发热、体重明显下降，或自我调整后仍长期便秘，优先咨询医生。
  </view>
</view>
