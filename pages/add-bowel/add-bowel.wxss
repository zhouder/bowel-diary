.entry-page {
  padding-top: 24rpx;
}

.entry-hero {
  margin-bottom: 22rpx;
  padding: 34rpx 32rpx;
  border-radius: 20rpx;
  background: #101412;
  color: #ffffff;
  box-shadow: 0 24rpx 60rpx rgba(16, 20, 18, 0.18);
}

.entry-kicker {
  color: rgba(255, 255, 255, 0.58);
  font-size: 21rpx;
  font-weight: 850;
}

.entry-title {
  margin-top: 12rpx;
  color: #ffffff;
  font-size: 50rpx;
  font-weight: 900;
  line-height: 1.08;
}

.entry-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.64);
  font-size: 27rpx;
  line-height: 1.45;
}

.form-section {
  padding-bottom: 32rpx;
}

.save-btn {
  margin-top: 6rpx;
}
