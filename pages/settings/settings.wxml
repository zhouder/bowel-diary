<view class="page settings-page">
  <view class="settings-hero">
    <text class="settings-kicker">Xiaomi MiMo</text>
    <view class="settings-title">Token Plan</view>
    <view class="settings-subtitle">OpenAI-compatible · China endpoint</view>
  </view>

  <view class="section">
    <view class="section-line">
      <view>
        <text class="eyebrow">API</text>
        <view class="section-title">AI 接口</view>
      </view>
      <view class="mini-btn" bindtap="useTokenPlanDefaults">默认</view>
    </view>
    <view class="field first-field">
      <text class="label">Base URL</text>
      <input class="input" value="{{settings.endpoint}}" data-key="endpoint" placeholder="{{defaults.endpoint}}" bindinput="onInput" />
    </view>
    <view class="field">
      <text class="label">模型</text>
      <input class="input" value="{{settings.model}}" data-key="model" placeholder="{{defaults.model}}" bindinput="onInput" />
    </view>
    <view class="field">
      <text class="label">API Key</text>
      <view class="secret-row">
        <input class="input" password="{{!showKey}}" value="{{settings.apiKey}}" data-key="apiKey" placeholder="tp-..." bindinput="onInput" />
        <view class="secondary-btn eye-btn" bindtap="toggleKey">{{showKey ? '藏' : '看'}}</view>
      </view>
    </view>
    <view class="primary-btn" bindtap="saveSettings">保存设置</view>
  </view>

  <view class="section">
    <view class="section-title">数据</view>
    <view class="data-actions">
      <view class="secondary-btn" bindtap="copyBackup">复制备份 JSON</view>
      <view class="secondary-btn" bindtap="importFromClipboard">从剪贴板导入</view>
      <view class="danger-btn" bindtap="clearRecords">清空记录</view>
    </view>
  </view>

  <view class="health-note">
    正式发布微信小程序时，需要把 AI 接口域名加入小程序后台 request 合法域名。开发阶段可在微信开发者工具里关闭域名校验。
  </view>
</view>
