.settings-page {
  padding-top: 24rpx;
}

.settings-hero {
  margin-bottom: 24rpx;
  padding: 22rpx 0 0;
}

.settings-kicker {
  color: #86868b;
  font-size: 24rpx;
  font-weight: 650;
}

.settings-title {
  margin-top: 8rpx;
  color: #1d1d1f;
  font-size: 60rpx;
  font-weight: 850;
  line-height: 1.05;
}

.settings-subtitle {
  margin-top: 10rpx;
  color: #6e6e73;
  font-size: 28rpx;
  line-height: 1.42;
}

.section-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.mini-btn {
  width: 128rpx;
  height: 64rpx;
  min-height: 64rpx;
  flex: 0 0 128rpx;
  padding: 0;
  border-radius: 18rpx;
  background: #f2f2f7;
  color: #007aff;
  font-size: 26rpx;
  font-weight: 750;
  line-height: 64rpx;
  text-align: center;
}

.first-field {
  margin-top: 24rpx;
}

.secret-row {
  display: flex;
  align-items: stretch;
  gap: 12rpx;
}

.secret-row .input {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
}

.eye-btn {
  width: 96rpx;
  height: 92rpx;
  min-height: 92rpx;
  flex: 0 0 96rpx;
  padding: 0;
  line-height: 92rpx;
}

.data-actions {
  display: grid;
  gap: 14rpx;
  margin-top: 22rpx;
}
