.settings-page {
  padding-top: 24rpx;
}

.settings-page .section {
  padding: 24rpx 26rpx 28rpx;
}

.section-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.mini-btn {
  width: 104rpx;
  height: 56rpx;
  min-height: 56rpx;
  flex: 0 0 104rpx;
  padding: 0;
  border-radius: 16rpx;
  background: #f2f2f7;
  color: #007aff;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 56rpx;
  text-align: center;
}

.first-field {
  margin-top: 0;
}

.secret-row {
  display: flex;
  align-items: stretch;
  gap: 12rpx;
}

.secret-row .input {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
}

.eye-btn {
  width: 88rpx;
  height: 88rpx;
  min-height: 88rpx;
  flex: 0 0 88rpx;
  padding: 0;
  line-height: 88rpx;
}

.data-actions {
  display: grid;
  gap: 12rpx;
  margin-top: 20rpx;
}
