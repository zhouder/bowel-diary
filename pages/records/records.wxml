<view class="page records-page">
  <view class="records-hero">
    <text class="records-kicker">TIMELINE</text>
    <view class="records-title">记录列表</view>
    <view class="segmented">
      <button class="seg {{active === 'bowels' ? 'active' : ''}}" data-tab="bowels" bindtap="switchTab">排便</button>
      <button class="seg {{active === 'meals' ? 'active' : ''}}" data-tab="meals" bindtap="switchTab">饮食</button>
    </view>
  </view>

  <view wx:if="{{active === 'bowels'}}" class="section">
    <view class="section-line">
      <view class="section-title">排便记录</view>
      <button class="mini-btn" bindtap="addBowel">新增</button>
    </view>
    <view wx:if="{{bowels.length}}">
      <view class="record-card" wx:for="{{bowels}}" wx:key="id">
        <view class="record-top">
          <view>
            <view class="record-title">{{item.bristolText}}</view>
            <view class="muted">{{item.timeText}} · {{item.minutes}} 分钟 · 顺畅度 {{item.ease}}</view>
          </view>
          <button class="delete-btn" data-id="{{item.id}}" bindtap="removeBowel">删</button>
        </view>
        <view class="record-note">{{item.detailText}}</view>
      </view>
    </view>
    <view wx:else class="empty">暂无排便记录</view>
  </view>

  <view wx:if="{{active === 'meals'}}" class="section">
    <view class="section-line">
      <view class="section-title">饮食记录</view>
      <button class="mini-btn" bindtap="addMeal">新增</button>
    </view>
    <view wx:if="{{meals.length}}">
      <view class="record-card" wx:for="{{meals}}" wx:key="id">
        <view class="record-top">
          <view>
            <view class="record-title">{{item.mealText}}</view>
            <view class="muted">{{item.timeText}} · 水 {{item.waterMl}} ml · 纤维 {{item.fiberGram}} g</view>
          </view>
          <button class="delete-btn" data-id="{{item.id}}" bindtap="removeMeal">删</button>
        </view>
        <view class="record-note">{{item.detailText}}</view>
      </view>
    </view>
    <view wx:else class="empty">暂无饮食记录</view>
  </view>
</view>
