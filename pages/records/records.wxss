.records-page {
  padding-top: 24rpx;
}

.segmented {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 6rpx;
  margin-top: 22rpx;
  padding: 5rpx;
  border-radius: 16rpx;
  background: #e9e9ee;
}

.seg {
  height: 62rpx;
  min-height: 62rpx;
  padding: 0;
  border-radius: 13rpx;
  color: #6e6e73;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 62rpx;
  text-align: center;
}

.seg.active {
  background: #ffffff;
  color: #1d1d1f;
  box-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.08);
}

.section-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 26rpx 18rpx;
}

.mini-btn {
  width: 104rpx;
  height: 56rpx;
  min-height: 56rpx;
  flex: 0 0 104rpx;
  padding: 0;
  border-radius: 16rpx;
  background: #f2f2f7;
  color: #007aff;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 56rpx;
  text-align: center;
}

.record-card {
  padding: 22rpx 26rpx;
  border-top: 1rpx solid rgba(60, 60, 67, 0.12);
}

.record-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 10rpx;
}

.record-title {
  color: #1d1d1f;
  font-size: 30rpx;
  font-weight: 600;
}

.record-note {
  color: #3a3a3c;
  font-size: 27rpx;
  line-height: 1.58;
}

.delete-btn {
  width: 64rpx;
  height: 54rpx;
  min-height: 54rpx;
  flex: 0 0 64rpx;
  padding: 0;
  border-radius: 15rpx;
  background: #fff1f0;
  color: #ff3b30;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 54rpx;
  text-align: center;
}

.records-page .empty {
  padding: 4rpx 26rpx 28rpx;
}
