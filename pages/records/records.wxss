.head-section {
  background: linear-gradient(135deg, #fffdf8 0%, #e4f2eb 100%);
}

.segmented {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 8rpx;
  border-radius: 16rpx;
  background: #f3efe7;
}

.seg {
  min-height: 70rpx;
  background: transparent;
  color: #6e6a61;
  font-weight: 800;
}

.seg.active {
  background: #ffffff;
  color: #22211f;
  box-shadow: 0 8rpx 20rpx rgba(61, 52, 38, 0.08);
}

.section-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.mini-btn {
  min-width: 112rpx;
  min-height: 60rpx;
  padding: 0 18rpx;
  border: 1rpx solid #ded8cd;
  background: #ffffff;
  color: #22211f;
  font-size: 26rpx;
  font-weight: 750;
}

.record-card {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #eee8dc;
}

.record-card:last-child {
  border-bottom: none;
}

.record-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 12rpx;
}

.record-title {
  color: #111111;
  font-size: 31rpx;
  font-weight: 820;
}

.record-note {
  color: #3f3728;
  font-size: 28rpx;
  line-height: 1.65;
}

.delete-btn {
  width: 66rpx;
  height: 58rpx;
  border: 1rpx solid rgba(185, 74, 74, 0.24);
  background: #fae6df;
  color: #b94a4a;
  font-size: 24rpx;
  font-weight: 800;
}
