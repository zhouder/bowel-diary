.records-page {
  padding-top: 24rpx;
}

.records-hero {
  margin-bottom: 24rpx;
  padding: 22rpx 0 0;
}

.records-kicker {
  color: #86868b;
  font-size: 24rpx;
  font-weight: 650;
}

.records-title {
  margin-top: 8rpx;
  color: #1d1d1f;
  font-size: 60rpx;
  font-weight: 850;
  line-height: 1.05;
}

.segmented {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 8rpx;
  margin-top: 24rpx;
  padding: 6rpx;
  border-radius: 18rpx;
  background: #e9e9ee;
}

.seg {
  height: 68rpx;
  min-height: 68rpx;
  padding: 0;
  border-radius: 14rpx;
  color: #6e6e73;
  font-size: 28rpx;
  font-weight: 750;
  line-height: 68rpx;
  text-align: center;
}

.seg.active {
  background: #ffffff;
  color: #1d1d1f;
  box-shadow: 0 5rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.mini-btn {
  width: 128rpx;
  height: 64rpx;
  min-height: 64rpx;
  flex: 0 0 128rpx;
  padding: 0;
  border-radius: 18rpx;
  background: #f2f2f7;
  color: #007aff;
  font-size: 26rpx;
  font-weight: 750;
  line-height: 64rpx;
  text-align: center;
}

.record-card {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(60, 60, 67, 0.12);
}

.record-card:last-child {
  border-bottom: none;
}

.record-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 12rpx;
}

.record-title {
  color: #1d1d1f;
  font-size: 31rpx;
  font-weight: 750;
}

.record-note {
  color: #3a3a3c;
  font-size: 27rpx;
  line-height: 1.65;
}

.delete-btn {
  width: 68rpx;
  height: 58rpx;
  min-height: 58rpx;
  flex: 0 0 68rpx;
  padding: 0;
  border-radius: 16rpx;
  background: #fff2f2;
  color: #ff3b30;
  font-size: 24rpx;
  font-weight: 750;
  line-height: 58rpx;
  text-align: center;
}
